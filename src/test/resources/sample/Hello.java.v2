package com.example;

import java.util.List;
import java.util.ArrayList;
import static java.util.Collections.unmodifiableList;

/**
 * A sample class for testing blob converters.
 *
 * @see Greeter
 */
public class Hello implements Greeter {
    private static final char SEPARATOR = ',';

    private static final double VERSION = 1.0;

    private final String name;

    private int count = 0;

    // Default constructor
    public Hello() {
        this("World");
    }

    public Hello(String name) {
        this.name = name;
    }

    @Override
    public String greet() {
        return "Hello" + SEPARATOR + ' ' + name + "!";
    }

    public String greet(boolean formal) {
        return formal ? "Dear " + name : greet();
    }

    public List<String> greetMany(int times) {
        List<String> results = new ArrayList<>();
        for (int i = 0; i < times; i++) {
            results.add(greet());
            count++;
        }
        return unmodifiableList(results);
    }

    public int getCount() {
        return count;
    }

    public static <T> String stringify(T value) {
        return value != null ? value.toString() : "null";
    }

    public static String[] toArray(List<String> list) {
        return list.toArray(new String[0]);
    }

    static class Formatter {
        private final String prefix;

        Formatter(String prefix) {
            this.prefix = prefix;
        }

        String format(String text) {
            return prefix + ": " + text;
        }
    }

    /**
     * A greeting interface.
     */
    @FunctionalInterface
    interface Greeter {
        String greet();

        default String greetLoud() {
            return greet().toUpperCase();
        }
    }

    enum Color {
        RED(0xFF0000),
        GREEN(0x00FF00),
        BLUE(0x0000FF);

        final int rgb;

        Color(int rgb) {
            this.rgb = rgb;
        }

        /* Returns hex representation */
        public String toHex() {
            try {
                return String.format("#%06x", rgb);
            } catch (Exception e) {
                return null;
            }
        }
    }
}
